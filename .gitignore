## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio Code specific
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Rider specific
.idea/

# Dotnet specific
project.lock.json
project.fragment.lock.json
project.assets.json
*.nuget.props
*.nuget.targets

# Mac files
*.DS_Store

# Temporary files
*.tmp
*.temp
*~

# Misc
*.dbmdl
*.dbproj.schemaview
*.pfx
*.key
*.aps
*.ncb
*.plg
*.opt
*.vmd
*.psess
*.vsp
*.vspx
*.sap
*.bak
*.cache
*_i.c
*_p.c
*.ilk
*.meta
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*.vssscc
*.builds
*.pidb
*.svclog
*.scc
*.tss

# Resharper specific
_ReSharper*/
*.[Rr]esharper
*.DotSettings.user

# Coverlet coverage results
coverage.*.json
coverage.*.xml

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# Test containers
*.testsettings

# App packages
*.appx
*.appxbundle
*.appxupload
*.msix
*.msixbundle
*.msixupload

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if you are using a packages.config file
#packages.config

# Microsoft User Secrets (often contains sensitive data)
**/secrets.json

# Environment variables
.env

# Thumbnails
Thumbs.db